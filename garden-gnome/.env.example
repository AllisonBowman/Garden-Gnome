# Copy this to `.env` and adjust. The app reads these as environment variables.
# (Phase 2 reads them directly from the environment; load this file via your
# shell, e.g. `set -a; source .env; set +a` before running uvicorn, or use
# your editor's env support.)

# --- Auth (user accounts; see the auth implementation plan) ---
# Required — the app refuses to boot without these two:
# JWT_SECRET=<openssl rand -hex 32>
# FERNET_KEY=<python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
# JWT_ALG=HS256
# ACCESS_TOKEN_TTL_MIN=30
# REFRESH_TOKEN_TTL_DAYS=90
# Provider credentials (needed from Phase 4 onward; see plan Phase 0):
# APPLE_BUNDLE_ID=app.gardengnome.ios
# APPLE_TEAM_ID=...
# APPLE_KEY_ID=...
# APPLE_PRIVATE_KEY_PATH=secrets/AuthKey_XXXX.p8
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com

# Which advice backend to use: stub | anthropic
ADVISOR_BACKEND=stub

# Backend for symptom diagnosis (free-text "what's wrong with my plant").
# Defaults to ADVISOR_BACKEND. The recommended hybrid: keep ADVISOR_BACKEND=stub
# for free, instant routine advice, and set this to anthropic so an LLM handles
# actual diagnosis (requires ANTHROPIC_API_KEY below; ~a third of a cent per call
# on the default Haiku model).
# ADVISOR_SYMPTOMS_BACKEND=anthropic

# --- Anthropic (cloud) settings, for later ---
# Used only when ADVISOR_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Vision backend for photo diagnosis (Phase 3). Only `stub` exists — no
# hosted vision backend is configured on purpose (species ID runs on-device
# in the mobile app). Readiness is reported at GET /ai/status.
VISION_BACKEND=stub

# --- Perenual API (catalog expansion) ---
# Premium-tier key for https://perenual.com — used only by the offline
# catalog-expansion pipeline (app/data/expansion/), never by the running app.
# The care-guide endpoint and the indoor filter are paid features.
# PERENUAL_API_KEY=sk-...

# --- Installation identity (auto-generated on first run, do not set manually) ---
# A stable UUID for this installation. Used to identify which GardenGnome
# deployment created a stewardship record in the census without exposing
# any user-identifiable information. Generated automatically by run_app.py
# and appended to this file on first launch.
# INSTALLATION_UUID=<auto-generated>

# --- Default environment (for new installations) ---
# The name and type of the environment auto-created on first startup.
# Type must be one of: home | nursery | community_garden | conservation | research
DEFAULT_ENV_NAME=My Garden
DEFAULT_ENV_TYPE=home

# --- Census sync (optional, opt-in) ---
# Set this to push anonymized plant data to a central census endpoint.
# If unset or empty, census sync is skipped (no data is sent anywhere).
# The export is PII-free: no nicknames, no notes, no personal identifiers --
# only species, environment type, geographic region, and care frequency.
# CENSUS_API_URL=https://census.gardengnome.example.com
