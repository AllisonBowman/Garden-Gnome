{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "macos-tahoe-26.5-xcode-26.6"
      },
      "env": {
        "EXPO_PUBLIC_SHOW_BACKEND_OVERRIDE": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "macos-tahoe-26.5-xcode-26.6"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SHOW_BACKEND_OVERRIDE": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "macos-tahoe-26.5-xcode-26.6"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
