{
  "expo": {
    "name": "PlantAdvocate",
    "slug": "garden-gnome",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.allisonbowman.plantadvocate",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.allisonbowman.gardengnome",
      "adaptiveIcon": {
        "backgroundColor": "#2D6A4F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F6FAF7"
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.997811516738-l75faapsrdvglh34tfj8vj15r0lcs0qt"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PlantAdvocate to access your camera to photograph plants."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PlantAdvocate to access your photos to add plant images."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2D6A4F"
        }
      ],
      "expo-status-bar",
      "./plugins/withGoogleModularHeaders",
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialCommunityIcons.ttf"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9f8bf927-1520-4e6f-ad37-c4fa5f70097e"
      }
    },
    "owner": "allisonbowman"
  }
}
